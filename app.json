{
  "expo": {
    "name": "KingzPlay",
    "slug": "KingzPlay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/images/KingzPlayerLogo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "assets/images/KingzPlaylogo2.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.kingplay",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yourname.kingplay",
      "compileSdkVersion": 36,
      "targetSdkVersion": 35,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/KingzPlaylogo.png"
      }
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      "expo-system-ui",
      [
        "expo-media-library",
        {
          "photosPermission": true,
          "savePhotosPermission": true,
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "36.0.0",
            "extraGradleProps": {
              "org.gradle.jvmargs": "-Xmx2048m -XX:MaxMetaspaceSize=512m"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "59e85fd2-3e8b-486d-9e93-11e2318c8e96"
      }
    }
  }
}
